// Numeric promotion tests
integer i = 42;
float f = 3.14;
double d = 2.718;

// integer -> float allowed
float f2 = i;
// integer -> double allowed
double d2 = i;
// float -> double allowed
double d3 = f;

// double -> float should be error
float f3 = d;

// exact matches are fine
integer i2 = i;
float f4 = f;
double d4 = d;
